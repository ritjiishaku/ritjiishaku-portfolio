---
const objections = [
  {
    q: "This sounds expensive for a small clinic.",
    a: "One missed appointment per day costs more than my monthly retainer. These systems pay for themselves within weeks."
  },
  {
    q: "Our staff won't know how to use it.",
    a: "I design for clinical staff, not tech people. If they can use WhatsApp, they can use what I build."
  },
  {
    q: "We've tried tech before and it failed.",
    a: "Most health tech fails because it was built by people who have never worked in a clinic. I have. That changes everything."
  }
];
---

<section class="bg-navy py-[48px] md:py-[80px] px-5 md:px-0 text-white">
  <div class="max-w-container mx-auto">
    <div class="reveal mb-12">
      <div class="text-[11px] font-medium uppercase tracking-[0.14em] text-blue mb-4 font-body">Common Questions</div>
      <h2 class="text-[26px] md:text-[38px] font-bold font-display leading-[1.2]">
        You probably have these questions.<br /> 
        Here are honest answers.
      </h2>
    </div>

    <div class="flex flex-col gap-6 md:gap-8">
      {objections.map((pair, index) => (
        <div class={`reveal reveal-delay-${index + 1} grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4`}>
          <!-- Question -->
          <div class="border-l-[3px] border-red-soft rounded-r-[8px] bg-[#D85A30]/[0.08] p-4">
            <div class="text-[9px] uppercase font-medium text-red-soft tracking-[0.1em] mb-1 font-body">Question</div>
            <p class="text-[13px] text-white/80 leading-[1.6] font-body">"{pair.q}"</p>
          </div>
          <!-- Answer -->
          <div class="border-l-[3px] border-green rounded-r-[8px] bg-[#1D9E75]/[0.08] p-4">
            <div class="text-[9px] uppercase font-medium text-green tracking-[0.1em] mb-1 font-body">Answer</div>
            <p class="text-[13px] text-white/80 leading-[1.6] font-body">{pair.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
