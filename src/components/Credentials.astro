---
const credentialCards = [
  {
    label: "5+ Years · Registered Nurse",
    title: "Clinical Experience",
     detail: "Active clinical nursing practice since 2020 — in real wards, with real patients, inside the systems I now automate. This is not background knowledge. It is the foundation that makes everything I build clinically intelligent."
  },
  {
    label: "Certified",
    title: "AI Automation Engineering",
     detail: "Certified in the full stack of modern AI automation — from building intelligent chatbots and multi-agent systems, to connecting them with the tools your clinic already uses. 4 real-world projects built, tested, and deployed in production."
  },
  {
    label: "UX/UI Design · Agentic Coding",
    title: "Design & Product",
     detail: "Trained in UX design and modern AI-assisted development. Every interface I build is tested for real-world usability — because a system that confuses your staff is a system that will not be used."
  }
];

const tools = [
  "OpenAI API", "n8n", "LangChain", "CrewAI", "LangGraph", "Flowise", 
  "ChromaDB", "Make", "Zapier", "WhatsApp API", "Streamlit", "Airtable"
];
---

<section id="credentials" class="bg-navy py-[48px] md:py-[80px] px-5 md:px-0 text-white">
  <div class="max-w-container mx-auto">
    <div class="reveal">
      <div class="text-[11px] font-medium uppercase tracking-[0.14em] text-blue mb-4 font-body">Credentials & Training</div>
      <h2 class="text-[26px] md:text-[38px] font-bold mb-3 font-display leading-[1.2]">
        Built on verified expertise.<br /> 
        Not just passion.
      </h2>
       <p class="text-[14px] text-white/60 mb-12 font-body">
         Every system I build is backed by formal certification, 
         hands-on project delivery, and 5 years of clinical practice.
       </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-12">
      {credentialCards.map((card, index) => (
        <div class={`reveal reveal-delay-${index + 1} bg-white/5 border border-white/10 rounded-[12px] p-5 flex flex-col`}>
          <div class="text-[11px] font-medium uppercase tracking-[0.1em] text-blue mb-2 font-body">{card.label}</div>
          <h3 class="text-[16px] font-bold text-white mb-3 font-display">{card.title}</h3>
          <p class="text-[13px] text-white/65 leading-[1.65] font-body">{card.detail}</p>
        </div>
      ))}
    </div>

    <div class="reveal reveal-delay-3">
      <div class="text-[11px] text-white/40 mb-4 font-body">Tools & frameworks I am certified to use:</div>
      <div class="flex flex-wrap gap-2">
        {tools.map(tool => (
          <span class="chip chip-dark">{tool}</span>
        ))}
      </div>
    </div>
  </div>
</section>
