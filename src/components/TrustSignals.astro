---
const stats = [
  {
    number: "5+",
    label: "Years of active clinical nursing practice"
  },
  {
    number: "4",
    label: "Real-world AI automation projects built and deployed"
  }
];
---

<section class="bg-[#F7F9FC] py-[48px] md:py-[80px] px-5 md:px-0">
  <div class="max-w-container mx-auto">
    <div class="reveal mb-12">
      <div class="text-[11px] font-medium uppercase tracking-[0.14em] text-blue mb-4 font-body">By the Numbers</div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      {stats.map((stat, index) => (
        <div class={`reveal reveal-delay-${index + 1} bg-white border border-[#E2E8F0] rounded-[12px] shadow-sm p-7 md:p-8 text-center`}>
          <div class="text-[48px] font-bold text-blue font-display leading-none mb-2">{stat.number}</div>
          <p class="text-[13px] text-muted leading-[1.5] font-body">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
