---
---

<section id="contact" class="relative bg-navy text-white py-[80px] md:py-[120px] px-5 md:px-0 overflow-hidden">
  <!-- Grid Background -->
  <div class="absolute inset-0 opacity-100" style="background-image: url('/bg/bg-grid-overlay.svg'); background-size: 32px 32px;"></div>
  
  <!-- Radial Glow -->
  <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full blur-[120px] opacity-30 pointer-events-none" 
       style="background: radial-gradient(circle, rgba(56,139,253,0.14) 0%, transparent 60%);">
  </div>

  <div class="max-w-container mx-auto text-center reveal px-5 md:px-0">
    <h2 class="text-[26px] md:text-[38px] font-bold font-display leading-[1.2] max-w-[600px] mx-auto mb-4">
      Let's find the one thing in your<br /> 
      clinic that AI can fix first.
    </h2>
    
    <p class="text-[14px] text-white/55 font-body leading-[1.65] max-w-[480px] mx-auto mb-10">
      Book a free 20-minute discovery call. No pitch. No pressure. 
      Just an honest conversation about where your biggest time 
      leak is — and whether I can fix it.
    </p>

    <div class="flex flex-col items-center gap-3">
      <button data-calendly-trigger class="btn-primary group">
        Book your free 20-minute call
        <img src="/icons/icon-arrow-right.svg" alt="" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
      </button>
      <p class="text-[11px] text-white/30 font-body">
        No commitment required &nbsp;·&nbsp; Remote, via Google Meet or WhatsApp &nbsp;·&nbsp; Available worldwide
      </p>
    </div>
  </div>
</section>
