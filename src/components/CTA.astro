---
---

<section class="relative bg-navy text-white py-[100px] md:py-[140px] px-5 md:px-0 overflow-hidden">
  <!-- Grid Background -->
  <div class="absolute inset-0 opacity-100" style="background-image: url('/bg/bg-grid-overlay.svg'); background-size: 32px 32px;"></div>
  
  <!-- Radial Glow -->
  <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full blur-[120px] opacity-30 pointer-events-none" 
       style="background: radial-gradient(circle, rgba(56,139,253,0.14) 0%, transparent 60%);">
  </div>

  <div class="max-w-container mx-auto text-center reveal px-5 md:px-0">
    <h2 class="text-[26px] md:text-[38px] font-bold font-display leading-[1.2] max-w-[600px] mx-auto mb-4">
      Let's find the one thing in your<br /> 
      clinic that AI can fix first.
    </h2>
    
     <p class="text-[14px] text-white/55 font-body leading-[1.65] max-w-[480px] mx-auto mb-6">
        Book a free 20-minute call. No pitch. No pressure. 
        Just an honest conversation about your biggest time 
        leak — and how we fix it.
      </p>

      <div class="flex flex-col items-center gap-3">
        <a
          href="#contact"
          class="btn-primary group w-full md:w-auto justify-center"
          aria-label="Go to contact form"
        >
           Book your free 20-minute call →
        </a>
      </div>
  </div>
</section>
